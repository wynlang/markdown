fn md_bold(text: string) -> string {
    return "<strong>" + text + "</strong>"
}

fn md_italic(text: string) -> string {
    return "<em>" + text + "</em>"
}

fn md_heading(level: int, text: string) -> string {
    return "<h" + int_to_string(level) + ">" + text + "</h" + int_to_string(level) + ">"
}

fn md_link(text: string, url: string) -> string {
    return "<a href=\"" + url + "\">" + text + "</a>"
}

test "bold" {
    assert_eq(md_bold("hello"), "<strong>hello</strong>")
}

test "italic" {
    assert_eq(md_italic("hello"), "<em>hello</em>")
}

test "h1" {
    assert_eq(md_heading(1, "Title"), "<h1>Title</h1>")
}

test "h2" {
    assert_eq(md_heading(2, "Sub"), "<h2>Sub</h2>")
}

test "link" {
    assert(md_link("Wyn", "https://wynlang.com").contains("href"))
}
